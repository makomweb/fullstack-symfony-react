<!doctype html>
{#
  Production Entry Point - Served by SpaController
  
  Used ONLY in production via Symfony backend (port 8080 at /spa)
  - Symfony renders this template with injected environment variables
  - Loads pre-compiled React app from /dist/main.js (optimized bundle)
  - Configuration values injected at runtime by SpaController
  
  Development uses frontend/index.html with Vite dev server instead.
#}
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>React + K8s demo app</title>
    <script>window.BACKEND_API_URL = "{{ backend_api_url }}";</script>
    <script>window.OTEL_COLLECTOR_ADDRESS = "{{ otel_collector_address }}";</script>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/dist/main.js"></script>
  </body>
</html>
