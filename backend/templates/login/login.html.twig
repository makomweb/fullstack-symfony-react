{% extends 'base.html.twig' %}

{% block title %}Sign In{% endblock %}

{% block body %}
    <!-- Login Section -->
    <section class="vh-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container py-5 h-100">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="card shadow-lg" style="border-radius: 1rem; border: none;">
                        <div class="card-body p-5">
                            <!-- Header -->
                            <div class="text-center mb-4">
                                <h2 class="card-title fw-bold">Welcome Back</h2>
                                <p class="text-muted small">Sign in to your account</p>
                            </div>

                            <!-- Error Alert -->
                            {% if error %}
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <strong>Login Failed:</strong> {{ error.messageKey|trans(error.messageData, 'security') }}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            {% endif %}

                            <!-- Already Logged In -->
                            {% if app.user %}
                                <div class="alert alert-info mb-4">
                                    <strong>Already signed in:</strong> You are logged in as <code>{{ app.user.userIdentifier }}</code>
                                    <br><small><a href="{{ path('app.logout') }}">Logout here</a> if you want to sign in with a different account.</small>
                                </div>
                            {% endif %}

                            <!-- Login Form -->
                            <form method="post" novalidate>
                                <!-- Email Field -->
                                <div class="mb-3">
                                    <label for="username" class="form-label fw-semibold">Email Address</label>
                                    <input 
                                        type="email" 
                                        value="{{ last_username }}" 
                                        name="_username" 
                                        id="username" 
                                        class="form-control form-control-lg" 
                                        placeholder="Enter your email"
                                        autocomplete="email" 
                                        required 
                                        autofocus
                                    >
                                    <small class="form-text text-muted">We'll never share your email.</small>
                                </div>

                                <!-- Password Field -->
                                <div class="mb-3">
                                    <label for="password" class="form-label fw-semibold">Password</label>
                                    <input 
                                        type="password" 
                                        name="_password" 
                                        id="password" 
                                        class="form-control form-control-lg" 
                                        placeholder="Enter your password"
                                        autocomplete="current-password" 
                                        required
                                    >
                                </div>

                                <!-- Remember Me -->
                                <div class="form-check mb-4">
                                    <input 
                                        class="form-check-input" 
                                        type="checkbox" 
                                        name="_remember_me" 
                                        id="_remember_me"
                                        value="on"
                                    >
                                    <label class="form-check-label" for="_remember_me">
                                        Remember me for 7 days
                                    </label>
                                </div>

                                <!-- CSRF Token -->
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                <!-- Target Path for post-login redirect -->
                                {% if app.request.query.get('_target_path') %}
                                    <input type="hidden" name="_target_path" value="{{ app.request.query.get('_target_path') }}">
                                {% endif %}

                                <!-- Submit Button -->
                                <button class="btn btn-lg btn-primary w-100 fw-semibold mb-3" type="submit">
                                    Sign In
                                </button>

                                <!-- Footer -->
                                <div class="text-center">
                                    <small class="text-muted">
                                        Need help? Contact your administrator.
                                    </small>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
