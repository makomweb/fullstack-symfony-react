{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": ">=3.2.2",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.3",
        "easycorp/easyadmin-bundle": "^5.0.4",
        "fakerphp/faker": "^1.24.1",
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "guzzlehttp/guzzle": "^7.10.0",
        "jolicode/automapper": "@dev",
        "makomweb/tactix": "^0.1.6",
        "nelmio/api-doc-bundle": "^5.9.5",
        "nelmio/cors-bundle": "^2.6.1",
        "open-telemetry/api": "^1.9.0",
        "open-telemetry/exporter-otlp": "^1.4.0",
        "open-telemetry/opentelemetry-auto-psr3": "^0.2",
        "open-telemetry/opentelemetry-auto-psr15": "^1.2.0",
        "open-telemetry/opentelemetry-auto-psr18": "^1.2.0",
        "open-telemetry/opentelemetry-auto-symfony": "^1.2.0@beta",
        "open-telemetry/sdk": "^1.14.0",
        "open-telemetry/sem-conv": "^1.38.0",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpstan/phpdoc-parser": "^2.3.2",
        "predis/predis": "^3.4.2",
        "squizlabs/php_codesniffer": "^4.0.1",
        "symfony/amqp-messenger": "^8.0.6",
        "symfony/asset": "^8.0.8",
        "symfony/cache": "^8.0.8",
        "symfony/clock": "^8.0.8",
        "symfony/config": "^8.0.8",
        "symfony/console": "^8.0.8",
        "symfony/dependency-injection": "^8.0.8",
        "symfony/doctrine-bridge": "^8.0.8",
        "symfony/doctrine-messenger": "^8.0.6",
        "symfony/dom-crawler": "^8.0.8",
        "symfony/dotenv": "^8.0.8",
        "symfony/error-handler": "^8.0.8",
        "symfony/event-dispatcher": "^8.0.8",
        "symfony/expression-language": "^8.0.8",
        "symfony/filesystem": "^8.0.8",
        "symfony/finder": "^8.0.8",
        "symfony/flex": "^2.10.0",
        "symfony/form": "^8.0.8",
        "symfony/framework-bundle": "^8.0.8",
        "symfony/http-foundation": "^8.0.8",
        "symfony/http-kernel": "^8.0.8",
        "symfony/intl": "^8.0.8",
        "symfony/lock": "^8.0.8",
        "symfony/messenger": "^8.0.8",
        "symfony/mime": "^8.0.8",
        "symfony/monolog-bridge": "^8.0.8",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/options-resolver": "^8.0.8",
        "symfony/password-hasher": "^8.0.8",
        "symfony/process": "^8.0.8",
        "symfony/property-access": "^8.0.8",
        "symfony/property-info": "^8.0.8",
        "symfony/routing": "^8.0.8",
        "symfony/runtime": "^8.0.8",
        "symfony/security-bundle": "^8.0.8",
        "symfony/security-core": "^8.0.8",
        "symfony/security-csrf": "^8.0.8",
        "symfony/security-http": "^8.0.8",
        "symfony/serializer": "^8.0.8",
        "symfony/string": "^8.0.8",
        "symfony/translation": "^8.0.8",
        "symfony/twig-bridge": "^8.0.8",
        "symfony/twig-bundle": "^8.0.8",
        "symfony/type-info": "^8.0.8",
        "symfony/uid": "^8.0.8",
        "symfony/validator": "^8.0.8",
        "symfony/var-dumper": "^8.0.8",
        "symfony/var-exporter": "^8.0.8",
        "symfony/yaml": "^8.0.8",
        "twig/extra-bundle": "^2.12|^3.24.0",
        "twig/intl-extra": "^3.24.0",
        "twig/twig": "^3.24.0",
        "xmolecules/phpmolecules": "^0.2.0"
    },
    "require-dev": {
        "deptrac/deptrac": "^4.6.0",
        "laudis/neo4j-php-client": "^3.4.3",
        "phpdocumentor/reflection": "^6.4.4",
        "phpstan/phpstan": "^2.1.46",
        "phpunit/phpunit": "^13.0.6",
        "symfony/browser-kit": "^8.0.8",
        "symfony/css-selector": "^8.0.8",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/phpunit-bridge": "^8.0.8",
        "symfony/stopwatch": "^8.0.8",
        "symfony/web-profiler-bundle": "^8.0.8"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": false,
            "tbachert/spi": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "qa": [
            "vendor/bin/phpstan analyse --memory-limit=1G",
            "vendor/bin/php-cs-fixer fix",
            "APP_ENV=test bin/phpunit",
            "vendor/bin/phpcs --standard=ruleset.xml src/Game/",
            "vendor/bin/deptrac analyse --report-uncovered"
        ],
        "sa": "vendor/bin/phpstan analyse --memory-limit=1G",
        "test": "APP_ENV=test bin/phpunit",
        "coverage": "bin/phpunit --coverage-text",
        "cs": "vendor/bin/php-cs-fixer check",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "lint": "vendor/bin/phpcs",
        "lint-fix": "vendor/bin/phpcbf",
        "arch": "vendor/bin/deptrac analyse --report-uncovered",
        "clear": [
            "bin/console cache:clear",
            "bin/console cache:clear --env=test",
            "bin/console cache:pool:clear --all",
            "bin/console cache:pool:clear --all --env=test"
        ],
        "complexity": "vendor/bin/phpcs --standard=ruleset.xml src/Game/"
    },
    "scripts-descriptions": {
        "lint": "Show all current linting errors according to PSR12",
        "lint-fix": "Show and fix all current linting errors according to PSR12",
        "sa": "Run the static analyzer",
        "test": "Run all tests locally",
        "clear": "Clear app cache and all cache pools"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        }
    }
}
